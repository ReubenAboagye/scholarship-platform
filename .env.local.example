# ============================================================
# ScholarMatch Platform — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── OpenRouter (LLM inference + embeddings) ──────────────────
# Handles both scholarship matching (chat) and embeddings (text-embedding-3-small).
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Model to use for match explanations.
# Good cheap options:
#   google/gemma-4-26b-a4b-it:free  ← default (free tier)
#   google/gemini-2.0-flash-001
#   openai/gpt-4o-mini
# Browse all models: https://openrouter.ai/models
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free

# ── Resend (transactional email) ──────────────────────────────
# Required for weekly digest and deadline reminder emails.
# Get your key at: https://resend.com/api-keys
# Free tier: 3,000 emails/month, 100/day.
RESEND_API_KEY=re_...

# ── Cron secret ───────────────────────────────────────────────
# Shared secret used to authenticate POST requests to:
#   /api/email/digest    — weekly digest (run every Sunday)
#   /api/email/reminders — deadline reminders (run daily)
# Set the same value here and in your scheduler (Supabase cron,
# GitHub Actions, EasyCron, etc.) as the X-Cron-Secret header.
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret-here

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ScholarMatch
